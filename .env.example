# ============================================================
# ニノヘミライ 環境変数テンプレート
# 本番値はこのファイルに書かず、GitHub Secrets / Vercel 環境変数に設定してください
# ============================================================

# ---------- サイト設定 ----------
NEXT_PUBLIC_SITE_URL=https://ninohe-mirai.example.com

# ---------- 外部データ API ----------
# e-Stat API（政府統計の総合窓口）
# 取得先: https://www.e-stat.go.jp/api/
ESTAT_APP_ID=your_estat_app_id_here

# RESAS API（地域経済分析システム）
# 取得先: https://opendata.resas-portal.go.jp/
RESAS_API_KEY=your_resas_api_key_here

# ---------- YouTube Data API v3 ----------
# 取得先: https://console.cloud.google.com/ → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# 二戸市議会YouTubeチャンネルID
# 取得方法: チャンネルページ → ソース内 "channelId" または /about ページのURL末尾
COUNCIL_YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------- Supabase ----------
# 取得先: https://supabase.com → プロジェクト設定 → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ---------- Anthropic (Claude API) ----------
# 取得先: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ---------- Vercel デプロイ ----------
VERCEL_TOKEN=your_vercel_token_here
VERCEL_ORG_ID=your_vercel_org_id_here
VERCEL_PROJECT_ID=your_vercel_project_id_here
