# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — 値入りファイルは絶対にコミットしない
.env
.env.local
.env.*.local
# .env.example はコミット対象（値なしテンプレート）

# raw data (API取得の生データは大きいためgitignore推奨)
# data/raw/ — 必要なら除外コメントアウト

# private data
data/raw/private/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
